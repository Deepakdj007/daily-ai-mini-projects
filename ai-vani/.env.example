# LiveKit (get from https://livekit.io → your project — free dev tier)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key_here
LIVEKIT_API_SECRET=your_api_secret_here

# Sarvam AI — used for STT, TTS, and LLM (get from https://dashboard.sarvam.ai)
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_LLM_BASE_URL=https://api.sarvam.ai/v1
SARVAM_LLM_MODEL=sarvam-30b

# Agent config
DEFAULT_LANGUAGE=ml-IN
BUSINESS_NAME=My Clinic

# Database (SQLite — relative to project root)
DB_PATH=data/vani.db
