# VoiceBot Demo — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Retell AI ──────────────────────────────────────────────────
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx
RETELL_FROM_NUMBER=+1xxxxxxxxxx          # Phone number registered in Retell
RETELL_WEBHOOK_SECRET=                   # Optional but recommended

# ── Sarvam AI ──────────────────────────────────────────────────
SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ── App Config ─────────────────────────────────────────────────
APP_ENV=development                      # development | production
WEBHOOK_BASE_URL=https://xxxx.ngrok.io  # Your public URL for Retell webhooks
DATABASE_URL=sqlite+aiosqlite:///./voicebot.db

# ── Frontend (Vite) ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
