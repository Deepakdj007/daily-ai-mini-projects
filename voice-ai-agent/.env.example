# LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pipeline preset (see README)
# current_en | sarvam_gemini | sarvam_googletts | soniox_gemini | sarvam_full | soniox_full | gcp_gemini | hybrid_budget
VOICE_PIPELINE_PRESET=current_en

# Optional: override preset per stage
# STT_PROVIDER=deepgram
# LLM_PROVIDER=google
# TTS_PROVIDER=deepgram
# LANGUAGE_PROFILE=en

# Required for current_en, soniox_*, hybrid_budget (TTS)
DEEPGRAM_API_KEY=

# Required for all presets using Gemini LLM (most presets)
GOOGLE_API_KEY=

# Required for sarvam_* and hybrid_budget (STT)
SARVAM_API_KEY=

# Required for soniox_* and hybrid_budget (TTS)
SONIOX_API_KEY=

# Required for gcp_gemini (Google Cloud STT + TTS — not AI Studio alone)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional tuning
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MAX_OUTPUT_TOKENS=80
# SARVAM_LLM_MODEL=sarvam-30b
# SONIOX_TTS_VOICE=Maya
# GOOGLE_TTS_MODEL=gemini-2.5-flash-tts
# GOOGLE_TTS_VOICE_NAME=Achernar
# GOOGLE_STT_LOCATION=asia-southeast1
