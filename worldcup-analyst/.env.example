# Groq API key — free, no credit card: https://console.groq.com/keys
GROQ_API_KEY=

# football-data.org token — free by email, no credit card:
# https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# Tavily — OPTIONAL. Free, no credit card (1000 searches/mo): https://app.tavily.com
# Enables team-targeted news search in the news agent. Without it, the agent
# still works from the keyless BBC + Guardian RSS feeds.
TAVILY_API_KEY=

# Optional: LangSmith tracing. Leave blank to disable.
LANGSMITH_API_KEY=
